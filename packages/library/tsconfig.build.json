{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@effectai/protocol (build)",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["src/node.ts"],
  "exclude": ["src/browser.ts", "**/*.spec.ts", "**/*.test.ts", "node_modules", "dist"]
}
