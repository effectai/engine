{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@effectai/payment (node build)",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./clients/js",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["clients/js/**/*.ts"],
  "exclude": [
    "clients/js/browser.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "node_modules",
    "dist"
  ]
}
