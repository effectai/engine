{
  "name": "@effectai/migration",
  "private": true,
  "type": "module",
  "scripts": {
    "build:node": "tsc -p tsconfig.build.json",
    "compile:ts": "pnpm run build:node",
    "fix:generated": "node --experimental-strip-types ../../tools/scripts/solana/fix-generated-imports.ts migration",
    "generate:clients": "node --experimental-strip-types ../../tools/scripts/solana/generate-clients.ts migration && pnpm run fix:generated",
    "build": "pnpm run generate:clients && pnpm run compile:ts",
    "clean": "rm -rf dist"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@solana/kit": "^2.1.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^20.11.7",
    "codama": "^1.3.3",
    "@codama/nodes-from-anchor": "^1.2.5",
    "@codama/renderers-js": "^1.2.13"
  }
}
